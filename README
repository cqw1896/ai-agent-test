  516  ollama pull nomic-embed-text
  517  uv add langchain-ollama
  518  uv add langchain-deepseek
  519  uv pip freeze >langchain-deepseek-4.txt
  520  uv add chromadb
  521  uv pip freeze >langchain-chromadb-5.txt
